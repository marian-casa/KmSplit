# Copiar este archivo a .env y completar con tus propios valores.
# El .env real NUNCA se sube al repo (ver .gitignore).

DEBUG=True
SECRET_KEY=cambiar-esto-por-una-clave-larga-y-random

# Debe coincidir con lo definido en docker-compose.yml
POSTGRES_DB=kmsplit
POSTGRES_USER=kmsplit_user
POSTGRES_PASSWORD=kmsplit_pass
POSTGRES_HOST=db
POSTGRES_PORT=5432

ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:4200
